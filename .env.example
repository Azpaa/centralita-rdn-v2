# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App URL (tu dominio de producción o tunnel URL para desarrollo)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# URL fallback del instalador desktop (solo si latest.json no apunta a un asset valido)
VOICE_AGENT_DOWNLOAD_URL=https://github.com/Azpaa/centralita-rdn-v2/releases/download/v0.1.0/RDN.Voice.Agent_0.1.0_x64-setup.exe

# Seed admin (solo para el script seed-admin.ts)
